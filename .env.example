# Email Notification Settings
# Set to 'true' to enable email notifications
EMAIL_ENABLED=true

# Your Gmail address used to send notifications
SENDER_EMAIL=your_sending_email@gmail.com

# 16-character App Password (NOT your login password)
# Generate at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=xxxx xxxx xxxx xxxx

# Email address to receive the alerts
RECEIVER_EMAIL=your_receiving_email@gmail.com
